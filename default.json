{
  "extends": [
    // we use almost the full `config:best-practices` preset
    // but we don't enable `docker:pinDigests` because we have many self-hosted consumers who would be forced to update each week
    // also `:pinDevDependencies` is disabled as it's too npm-specific, we have packageRules for that
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver",
    ":configMigration",
    "abandonments:recommended",
    "security:minimumReleaseAgeNpm",
    ":maintainLockFilesWeekly",
    // to massively reduce noice, we only get 2 PRs: update all non-major deps + lockfile maintenance
    "group:allNonMajor",
    // sets rangeStrategy to replace globally, overridden by package rules
    ":preserveSemverRanges",
    ":prHourlyLimitNone",
    // run once a week to reduce noise. Every monday we deal with renovate and forget about it for the rest of the week
    "schedule:weekly"
  ],
  "timezone": "UTC",
  // setting it to any other value made renovate update already open PRs even outside schedule
  "recreateWhen": "never",
  // we update the constraint when our global minimum python changes
  "constraints": {
    "python": ">=3.12,<3.13"
  },
  // absolutely no activity outside of schedule, unless we manually trigger it or it's a security update
  "updateNotScheduled": false,
  // supply chain security, note that it must also be configured in each package manager using their own implementations to the same value
  "minimumReleaseAge": "7 days",
  // useful table of changed dependencies in renovate commits
  "commitBodyTable": true,
  // as per our labels convention
  "labels": ["type: chore"],
  // security updates bypass any schedules
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["type: security"]
  },
  "osvVulnerabilityAlerts": true,
  // pre-commit is not enabled by default in renovate
  "pre-commit": {
    "enabled": true
  },
  // we might explore it in the future, explicitly disabling it for now
  "semanticCommits": "disabled",
  // technically it is the default, but just to be sure
  "internalChecksFilter": "strict",
  // those are too noisy
  "suppressNotifications": ["prEditedNotification"],
  "packageRules": [
    {
      "description": "We set only the lower bound for python deps, so we want to update lockfile and still see changelogs",
      "matchManagers": ["pep621"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "description": "Lockfile maintenance doesn't support minimumReleaseAge, but our package managers validate it themselves",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "minimumReleaseAge": null
    },
    // this rule is used to override `security:minimumReleaseAgeNpm` default of 3 days
    {
      "description": "All npm package updates must wait for 7 days to align with pnpm minimumReleaseAge",
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Skip minimum release age for cutting edge tools we deliberately use and update often",
      "matchPackageNames": [
        "oxfmt",
        "oxlint",
        "oxfmt-*",
        "oxlint-*",
        "@base-ui/*"
      ],
      "minimumReleaseAge": null
    },
    {
      "description": "The package is not abandoned, but feature-complete",
      "abandonmentThreshold": null,
      "matchDatasources": ["npm"],
      "matchPackageNames": ["class-variance-authority"]
    },
    {
      "description": "Require dashboard approval for major updates",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Require approval for go cli package as it updates too often",
      "matchDatasources": ["go"],
      "matchPackageNames": ["github.com/urfave/cli/v2"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group prettier packages on major bumps",
      "matchPackageNames": ["prettier", "@prettier/*", "prettier-plugin-*"],
      "matchUpdateTypes": ["major"],
      "groupName": "prettier packages"
    },
    {
      "description": "Group all OpenTelemetry python packages from both upstream monorepos",
      "extends": [
        "monorepo:opentelemetry-python",
        "monorepo:opentelemetry-python-contrib"
      ],
      "groupName": "opentelemetry packages",
      // opentelemetry-distro and others are classified as "major" while e.g. sdk as "minor"
      "separateMajorMinor": false,
      // opentelemetry-distro/-instrumentation ship as pep440 pre-releases
      "ignoreUnstable": false
    },
    {
      "description": "Forgejo doesn't support actions/download-artifact and actions/upload-artifact above v3",
      "matchManagers": ["github-actions"],
      "matchFileNames": [".forgejo/**"],
      "matchPackageNames": [
        "actions/download-artifact",
        "actions/upload-artifact"
      ],
      "enabled": false
    },
    {
      "description": "Don't pin our reusable bitcart/bitcart-actions for ease of propagation across all repositories",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["bitcart/bitcart-actions/**"],
      "pinDigests": false
    },
    {
      "description": "Fold github-actions digest-only bumps into the weekly non-major PR",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest"],
      "extends": ["group:allNonMajor"]
    }
  ],
  "postUpdateOptions": ["gomodTidy", "pnpmDedupe"]
}
