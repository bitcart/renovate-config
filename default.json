{
  "extends": [
    "config:recommended",
    ":configMigration",
    "abandonments:recommended",
    "security:minimumReleaseAgeNpm",
    ":maintainLockFilesWeekly",
    "group:allNonMajor",
    ":preserveSemverRanges",
    ":prHourlyLimitNone",
    "schedule:weekly"
  ],
  "timezone": "UTC",
  "recreateWhen": "never",
  "constraints": {
    "python": ">=3.12,<3.13"
  },
  "updateNotScheduled": false,
  "minimumReleaseAge": "7 days",
  "commitBodyTable": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["type: security"]
  },
  "osvVulnerabilityAlerts": true,
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Lockfile maintenance doesn't support minimumReleaseAge, but our package managers validate it themselves",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "minimumReleaseAge": null
    },
    {
      "description": "All npm package updates must wait for 7 days to align with pnpm minimumReleaseAge",
      "internalChecksFilter": "strict",
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "All Python package updates must wait for 7 days to align with uv exclude-newer",
      "internalChecksFilter": "strict",
      "matchDatasources": ["pypi"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Skip minimum release age for oxc tools",
      "matchPackageNames": ["oxfmt", "oxlint", "oxfmt-*", "oxlint-*"],
      "minimumReleaseAge": null
    },
    {
      "description": "The package is not abandoned, but feature-complete",
      "abandonmentThreshold": null,
      "matchDatasources": ["npm"],
      "matchPackageNames": ["class-variance-authority"]
    },
    {
      "description": "Require dashboard approval for major updates",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Require approval for new vuetify release series",
      "dependencyDashboardApproval": true,
      "matchPackageNames": ["vuetify"],
      "matchUpdateTypes": ["major", "minor"]
    },
    {
      "description": "Require approval for every nuxt update",
      "dependencyDashboardApproval": true,
      "matchPackageNames": ["/nuxt/"],
      "groupName": "nuxt packages"
    },
    {
      "description": "Require approval for go cli package as it updates too often",
      "matchDatasources": ["go"],
      "matchPackageNames": ["github.com/urfave/cli/v2"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group prettier packages",
      "matchPackageNames": ["prettier", "@prettier/*", "prettier-plugin-*"],
      "groupName": "prettier packages"
    },
    {
      "description": "Forgejo doesn't support actions/download-artifact and actions/upload-artifact above v3",
      "matchManagers": ["github-actions"],
      "matchFileNames": [".forgejo/**"],
      "matchPackageNames": [
        "actions/download-artifact",
        "actions/upload-artifact"
      ],
      "enabled": false
    }
  ],
  "postUpdateOptions": ["gomodTidy", "pnpmDedupe"]
}
